# useSend MCP configuration (prefix: USESEND_). Copy to .env and adjust.
USESEND_API_KEY=us_your_api_key_here
# Optional: self-hosted base URL (default https://app.usesend.com)
# USESEND_BASE_URL=https://app.usesend.com
# Optional: default sender used when a tool's from_address is omitted
# USESEND_DEFAULT_FROM=no-reply@yourdomain.com
# USESEND_LOG_LEVEL=INFO
# USESEND_TIMEOUT=30
